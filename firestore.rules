rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && 
        (('email' in request.auth.token && request.auth.token.email == 'poriciti.web@gmail.com') || 
         ('email' in request.auth.token && request.auth.token.email == 'admin@poriciti.com') || 
         request.auth.uid == 'jTlKHWyYQjSa8WaP5uRZz5I3BvD3');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation (Pillar 2 & 5)
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'name', 'paymentStatus', 'socialLinks', 'createdAt', 'updatedAt'])
        // Exact size check on create is handled in the create block specifically
        && data.userId is string && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2000))
        && (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20))
        && (!('mobileNumber' in data) || (data.mobileNumber is string && data.mobileNumber.size() <= 20))
        && data.socialLinks is list && data.socialLinks.size() <= 20
        && (data.socialLinks.size() == 0 || (data.socialLinks[0].platform is string && data.socialLinks[0].platform.size() <= 50))
        && data.paymentStatus in ['pending', 'paid']
        && (!('views' in data) || (data.views is int && data.views >= 0))
        && (!('isSuspended' in data) || (data.isSuspended is bool))
        && (!('isVerified' in data) || (data.isVerified is bool))
        && (!('senderNumber' in data) || (data.senderNumber is string && data.senderNumber.size() <= 20))
        && (!('lastTrxId' in data) || (data.lastTrxId is string && data.lastTrxId.size() <= 100))
        && (!('expiryDate' in data) || (data.expiryDate is string && data.expiryDate.size() <= 100))
        && (!('paymentDate' in data) || (data.paymentDate is timestamp))
        && (!('referralCode' in data) || (data.referralCode is string && data.referralCode.size() <= 100))
        && (!('appliedReferral' in data) || (data.appliedReferral is string && data.appliedReferral.size() <= 100))
        && (!('bestFriendCode' in data) || (data.bestFriendCode is string && data.bestFriendCode.size() <= 100))
        && (!('bestFriendCodeCopied' in data) || (data.bestFriendCodeCopied is bool))
        && (!('bestFriendCodeUsed' in data) || (data.bestFriendCodeUsed is bool))
        && (!('bestFriendCodeUsedBy' in data) || (data.bestFriendCodeUsedBy is string && data.bestFriendCodeUsedBy.size() <= 100));
    }

    function isValidSettingsReferral(data) {
      return data.keys().hasAll(['friendDiscount', 'isGlobalEnabled', 'updatedAt'])
        && data.friendDiscount is int && data.friendDiscount >= 0 && data.friendDiscount <= 100
        && data.isGlobalEnabled is bool
        && data.updatedAt is timestamp;
    }

    function isValidReferralCode(data) {
      return data.keys().hasAll(['code', 'discount', 'isActive'])
        && data.code is string && data.code.size() > 0 && data.code.size() <= 100
        && data.discount is int && data.discount >= 0 && data.discount <= 100
        && data.isActive is bool;
    }

    match /test/connection {
      allow read: if true;
    }

    match /settings/referral {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidSettingsReferral(incoming());
    }

    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidReferralCode(incoming());
    }

    match /users/{userId} {
      // Admin Full Control
      allow read, write: if isAdmin();

      // PUBLIC READ: Profiles are public for viewing
      // Pillar 8: Explicitly evaluate resource.data for list queries
      allow get: if true;
      allow list: if isAdmin(); // Only admins can browse all users

      allow create: if isSignedIn()
        && isValidId(userId)
        && userId == request.auth.uid
        && isValidUser(incoming())
        // Pillar 2: Strict Keys on Create (avoid shadow fields)
        // required: userId, name, paymentStatus, socialLinks, createdAt, updatedAt
        // plus optional fields
        && incoming().keys().size() <= 23 // Max expected fields including new referral / friend fields
        && incoming().paymentStatus == 'pending'
        && (!('isVerified' in incoming()) || incoming().isVerified == false)
        && (!('isSuspended' in incoming()) || incoming().isSuspended == false)
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if (
        isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && (
          // Action 1: Basic Profile Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'bio', 'photoURL', 'socialLinks', 'mobileNumber', 'phoneNumber', 'updatedAt', 'referralCode', 'appliedReferral', 'bestFriendCode', 'bestFriendCodeCopied', 'bestFriendCodeUsed', 'bestFriendCodeUsedBy'])) ||
          
          // Action 2: Subscription Payment Submission
          (incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'senderNumber', 'lastTrxId', 'paymentDate', 'expiryDate', 'updatedAt', 'isSuspended', 'referralCode', 'appliedReferral', 'bestFriendCode', 'bestFriendCodeCopied', 'bestFriendCodeUsed', 'bestFriendCodeUsedBy']))
        ) && 
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time
      ) || (
        // Action 3: Public View Increment
        incoming().diff(existing()).affectedKeys().hasOnly(['views']) &&
        incoming().views == (existing().get('views', 0) + 1)
      ) || (
        // Action 4: Friend marking this Best Friend code as used. 
        // Highly secure: lets other registered users update ONLY 'bestFriendCodeUsed' and 'bestFriendCodeUsedBy', provided it wasn't used yet.
        isSignedIn() && userId != request.auth.uid && (
          incoming().diff(existing()).affectedKeys().hasOnly(['bestFriendCodeUsed', 'bestFriendCodeUsedBy']) &&
          existing().get('bestFriendCodeUsed', false) == false &&
          incoming().bestFriendCodeUsed == true &&
          incoming().bestFriendCodeUsedBy == request.auth.uid
        )
      );
      
      allow delete: if isAdmin();
    }
  }
}
